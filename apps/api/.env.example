DATABASE_URL=postgres://postgres:pg@localhost:5432/postgres
# Optional. If unset, leaderboard cache is disabled and the API still works.
# Local: redis://localhost:6379
# Railway/Lizard: provided automatically when you attach a Redis service.
REDIS_URL=
PORT=8080
CORS_ORIGIN=http://localhost:5173
# Domain (host, no scheme) where the mini app FRONTEND is served.
# Quick Auth issues JWTs scoped to this domain; the API verifies the `aud` claim against it.
# In prod set to your Railway web service hostname, e.g. 2048-web-production.up.railway.app
MINIAPP_DOMAIN=localhost

# Public origin where THIS api is reachable. The cast share URL is
# ${API_PUBLIC_URL}/share/:id; that page serves the fc:miniapp meta that
# Farcaster scrapes when the URL is pasted into a cast.
API_PUBLIC_URL=http://localhost:8080
# Public origin of the WEB app. Embedded in the share page meta as the
# launch_miniapp target so the cast preview button opens the game.
WEB_PUBLIC_URL=http://localhost:5173

# --- On-chain (Base) ---
# Base JSON-RPC endpoint. Defaults to the public node if unset.
BASE_RPC_URL=https://mainnet.base.org
# Required. Treasury address that receives pack purchases; must be a valid
# 0x-prefixed checksummed address. The API refuses to start without it.
TREASURY_ADDRESS=
# Confirmations required before a tx is considered final for undo/credit.
UNDO_MIN_CONFIRMATIONS=1

# Railway Object Storage (S3-compatible, virtual-hosted style). All four
# must be set for sharing to work; the share endpoint returns 503 otherwise.
# Public URL is derived as https://${S3_BUCKET}.${endpoint-host}/${key}.
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
