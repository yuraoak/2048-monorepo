DATABASE_URL=postgres://postgres:pg@localhost:5432/postgres
# Optional. If unset, leaderboard cache is disabled and the API still works.
# Local: redis://localhost:6379
# Railway/Lizard: provided automatically when you attach a Redis service.
REDIS_URL=
PORT=8080
CORS_ORIGIN=http://localhost:5173
# Domain (host, no scheme) where the mini app FRONTEND is served.
# Quick Auth issues JWTs scoped to this domain; the API verifies the `aud` claim against it.
# In prod set to your Railway web service hostname, e.g. 2048-web-production.up.railway.app
MINIAPP_DOMAIN=localhost
