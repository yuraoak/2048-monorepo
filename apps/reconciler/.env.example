# Reconciler (Go) — scans Base for treasury deposits and reconciles pack
# purchases against the DB. Shares DATABASE_URL with @app/api.
DATABASE_URL=postgres://postgres:pg@localhost:5432/postgres

# --- On-chain (Base) ---
# Base JSON-RPC endpoint. Defaults to the public node if unset.
BASE_RPC_URL=https://mainnet.base.org
# Required. Treasury address being watched for deposits; must be a valid
# 0x-prefixed address. The reconciler refuses to start without it.
TREASURY_ADDRESS=
# Confirmations required before a deposit is credited.
UNDO_MIN_CONFIRMATIONS=1

# --- Scanner knobs ---
# How often to scan for new blocks. Go duration string (e.g. 30s, 1m, 5m).
RECONCILER_INTERVAL=60s
# Cap on blocks scanned in one tick — bounds RPC pressure on burst recovery.
# Blocks within a tick are fetched concurrently (see SCAN_CONCURRENCY), so a
# few thousand per tick comfortably fits the tick timeout and lets the cursor
# catch up to head quickly after a redeploy.
RECONCILER_MAX_BLOCKS_PER_TICK=2000
# Number of block fetches issued in parallel within a tick. Higher = faster
# catch-up at the cost of more concurrent RPC load.
RECONCILER_SCAN_CONCURRENCY=16
# On the very first run (cursor=0) start this many blocks behind head instead
# of scanning all of Base history. Default 50000 ≈ ~28h on Base.
RECONCILER_INITIAL_LOOKBACK=50000
